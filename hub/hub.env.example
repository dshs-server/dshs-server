# Hub runtime secrets/config. Copy entries to $HOME/.hub.env; do not commit real values.
SSH_PASSWORD=change-me

# Session lifecycle
SESSION_RETENTION_DAYS=30
SESSION_WARNING_HOURS=24,1
DELETION_WARNING_DAYS=7,1
LIFECYCLE_CHECK_INTERVAL=60
PORTAL_URL=https://dshs-server.vercel.app/dashboard

# Email notifications — only a SendGrid API key is required with current defaults.
SMTP_PASSWORD=SG.replace-with-a-new-sendgrid-api-key

# Optional overrides (defaults shown)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_FROM=ai_admin@ts.hs.kr
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false

# Google app-password alternative (when enabled by Workspace policy)
# SMTP_HOST=smtp.gmail.com
# SMTP_USER=ai_admin@ts.hs.kr
# SMTP_PASSWORD=google-app-password

# Alternative for school Workspace accounts where app passwords are disabled.
# A Workspace admin must first allow the central PC's public IP in SMTP Relay.
# SMTP_HOST=smtp-relay.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=ai_admin@ts.hs.kr
# SMTP_USE_TLS=true
