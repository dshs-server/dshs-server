# 백엔드 서버 URL (backend/start.sh 실행 후 출력되는 URL)
BACKEND_URL=https://xxxx.trycloudflare.com

# 백엔드 API 키 (backend/start.sh의 API_KEY 환경변수와 동일하게 설정)
API_KEY=dev-secret-change-me

# 세션 쿠키 서명 시크릿 (랜덤 32자 이상 문자열 사용)
AUTH_SECRET=random-32-char-secret-change-me

# ---- Google 로그인 (@ts.hs.kr 전용) ----
# Google Cloud Console → 사용자 인증 정보 → OAuth 클라이언트 ID(웹)
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxx
# 승인된 리디렉션 URI에 다음을 등록:
#   https://<vercel-도메인>/api/auth/callback
#   http://localhost:3000/api/auth/callback   (로컬 개발용)

# 허용할 학교 이메일 도메인
ALLOWED_DOMAIN=ts.hs.kr

# 관리자 이메일 (쉼표로 여러 개) — /admin 패널 접근 권한
ADMIN_EMAILS=teacher@ts.hs.kr

# ---- 파일 전송 (대시보드 → 내 PC 바탕화면) ----
# 학생 브라우저가 파일을 직접 보낼 중앙 PC(허브)의 HTTPS 주소.
# 반드시 유효한 인증서가 있는 HTTPS여야 함 (HTTP면 브라우저가 mixed content로 차단).
# 학교 WiFi에서 이 주소가 중앙 PC LAN IP로 풀리도록 DNS 설정 필요.
HUB_LAN_URL=https://hub.dshs-app.net
# 업로드 토큰 서명 키 — 허브의 UPLOAD_SECRET과 동일해야 함. 비우면 API_KEY 재사용.
UPLOAD_SECRET=
